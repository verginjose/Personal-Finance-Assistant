{
  "uid": "finance-assistant",
  "title": "Finance Assistant",
  "tags": ["finance-assistant"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s","15s","30s","1m","5m"],
    "time_options": ["5m","15m","1h","3h","6h","12h","24h","2d","7d"]
  },
  "templating": {
    "list": [
      {
        "name": "service", "label": "Service", "type": "custom",
        "query": "api-gateway,auth-service,upsert-service,analytics-service,bill-parser-service",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All",                 "value": "$__all",             "selected": true  },
          { "text": "api-gateway",         "value": "api-gateway",        "selected": false },
          { "text": "auth-service",        "value": "auth-service",       "selected": false },
          { "text": "upsert-service",      "value": "upsert-service",     "selected": false },
          { "text": "analytics-service",   "value": "analytics-service",  "selected": false },
          { "text": "bill-parser-service", "value": "bill-parser-service","selected": false }
        ],
        "includeAll": true, "allValue": "%", "multi": false
      },
      {
        "name": "level", "label": "Log Level", "type": "custom",
        "query": "INFO,WARN,ERROR,DEBUG",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All",   "value": "$__all", "selected": true  },
          { "text": "INFO",  "value": "INFO",   "selected": false },
          { "text": "WARN",  "value": "WARN",   "selected": false },
          { "text": "ERROR", "value": "ERROR",  "selected": false },
          { "text": "DEBUG", "value": "DEBUG",  "selected": false }
        ],
        "includeAll": true, "allValue": "%", "multi": false
      },
      {
        "name": "search", "label": "Search", "type": "textbox",
        "current": { "text": "", "value": "" }, "query": ""
      }
    ]
  },
  "panels": [

    {
      "id": 1, "title": "api-gateway", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"api-gateway\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
        { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
      ], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2, "title": "auth-service", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"auth-service\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
        { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
      ], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3, "title": "upsert-service", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"upsert-service\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
        { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
      ], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 }
    },
    {
      "id": 4, "title": "analytics-service", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"analytics-service\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
        { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
      ], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 }
    },
    {
      "id": 5, "title": "bill-parser-service", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"bill-parser-service\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
        { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
      ], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 }
    },

    {
      "id": 6,
      "title": "Error Rate — per service (last 1h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{
        "expr": "sum by (service) (increase(pfa_log_errors_total[1m]))",
        "legendFormat": "{{service}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 3 }
    },

    {
      "id": 10,
      "title": "Logs — $service | $level | $search",
      "type": "logs",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [{
        "queryType": "sql",
        "rawSql": "SELECT timestamp, if(stack_trace != '', concat(message, char(10), stack_trace), message) as message, service, level FROM default.logs WHERE service ILIKE '$service' AND level ILIKE '$level' AND message ILIKE '%${search}%' AND $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 500",
        "refId": "A",
        "format": "logs"
      }],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "level" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "ERROR": { "color": "red",    "index": 0 } } },
                  { "type": "value", "options": { "WARN":  { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "INFO":  { "color": "green",  "index": 2 } } },
                  { "type": "value", "options": { "DEBUG": { "color": "blue",   "index": 3 } } }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 30, "w": 24, "x": 0, "y": 9 }
    }
  ]
}