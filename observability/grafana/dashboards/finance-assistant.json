{
  "uid": "finance-assistant",
  "title": "Finance Assistant",
  "tags": ["finance-assistant"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "query": "api-gateway,auth-service,upsert-service,analytics-service,bill-parser-service",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All",                 "value": "$__all",           "selected": true  },
          { "text": "api-gateway",         "value": "api-gateway",        "selected": false },
          { "text": "auth-service",        "value": "auth-service",       "selected": false },
          { "text": "upsert-service",      "value": "upsert-service",     "selected": false },
          { "text": "analytics-service",   "value": "analytics-service",  "selected": false },
          { "text": "bill-parser-service", "value": "bill-parser-service","selected": false }
        ],
        "includeAll": true,
        "allValue": ".+",
        "multi": false
      },
      {
        "name": "level",
        "label": "Log Level",
        "type": "custom",
        "query": "INFO,WARN,ERROR,DEBUG",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All",   "value": "$__all", "selected": true  },
          { "text": "INFO",  "value": "INFO",   "selected": false },
          { "text": "WARN",  "value": "WARN",   "selected": false },
          { "text": "ERROR", "value": "ERROR",  "selected": false },
          { "text": "DEBUG", "value": "DEBUG",  "selected": false }
        ],
        "includeAll": true,
        "allValue": ".*",
        "multi": false
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "api-gateway",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"api-gateway\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "auth-service",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"auth-service\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3,
      "title": "upsert-service",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"upsert-service\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 }
    },
    {
      "id": 4,
      "title": "analytics-service",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"analytics-service\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 }
    },
    {
      "id": 5,
      "title": "bill-parser-service",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [{ "expr": "up{job=\"bill-parser-service\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 }
    },

    {
      "id": 20,
      "title": "Error Rate — last 1h",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[2m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 3 }
    },
    {
      "id": 21,
      "title": "ERROR log count by service — last 1h",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({level=\"ERROR\"}[2m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 3 }
    },

    {
      "id": 10,
      "title": "Logs — $service  |  level: $level  |  search: $search",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | level=~\"$level\" |= `${search:raw}`",
          "refId": "A",
          "queryType": "range",
          "maxLines": 500
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending",

        "scrollToBottom": false
      },
      "transformations": [],
      "gridPos": { "h": 35, "w": 24, "x": 0, "y": 9 }
    }
  ]
}