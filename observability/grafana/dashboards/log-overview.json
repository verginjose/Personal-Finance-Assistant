{
  "title": "Container Log Overview",
  "tags": ["finance-assistant", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Service (last 1h)",
      "type": "bargauge",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-ds"
      },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT source, count() AS total FROM observability_logs.container_logs WHERE timestamp > now() - INTERVAL 1 HOUR GROUP BY source ORDER BY total DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^total$/", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Recent Error Logs (last 1h)",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-ds"
      },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT timestamp, source, log FROM observability_logs.container_logs WHERE timestamp > now() - INTERVAL 1 HOUR AND (positionCaseInsensitive(log, 'error') > 0 OR positionCaseInsensitive(log, 'exception') > 0) ORDER BY timestamp DESC LIMIT 100",
          "refId": "A",
          "format": "table"
        }
      ],
      "options": { "sortBy": [{ "displayName": "timestamp", "desc": true }] },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "source" }, "properties": [{ "id": "custom.width", "value": 140 }] },
          { "matcher": { "id": "byName", "options": "log" }, "properties": [{ "id": "custom.width", "value": 600 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Hourly Log Volume (all services)",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-ds"
      },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toStartOfHour(timestamp) AS time, source, count() AS logs FROM observability_logs.container_logs WHERE timestamp >= now() - INTERVAL 6 HOUR GROUP BY time, source ORDER BY time",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Total Log Count (last 1h)",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-ds"
      },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT count() AS total_logs FROM observability_logs.container_logs WHERE timestamp > now() - INTERVAL 1 HOUR",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 }
    },
    {
      "id": 5,
      "title": "Error Count (last 1h)",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-ds"
      },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT count() AS errors FROM observability_logs.container_logs WHERE timestamp > now() - INTERVAL 1 HOUR AND (positionCaseInsensitive(log,'error') > 0 OR positionCaseInsensitive(log,'exception') > 0)",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 }
    }
  ]
}
