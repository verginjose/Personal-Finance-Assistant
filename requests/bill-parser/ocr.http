#!/usr/bin/env python3
"""
Personal Finance Assistant — API Test Suite
Services: Auth · Upsert · Analytics · Split · OCR/Bill Parser

Usage:
    python test_api.py
    python test_api.py --url http://localhost:8080
    python test_api.py --email user@test.com --password secret
    python test_api.py --ocr-images 1.webp 2.png 3.jpg
    python test_api.py --ocr-pdfs invoice.pdf receipt.pdf
    python test_api.py --skip-ocr
    python test_api.py --fail-fast
"""

import argparse
import os
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path
from typing import Any

import requests

# ── CLI args ──────────────────────────────────────────────────────────────────
parser = argparse.ArgumentParser(description="PFA API Test Suite")
parser.add_argument("--url",        default="http://localhost:8080")
parser.add_argument("--email",      default="testverify@gmail.com")
parser.add_argument("--password",   default="tempPass123")
parser.add_argument("--new-email",  default="testverify2@gmail.com")
parser.add_argument("--ocr-images", nargs="+", default=[], metavar="FILE")
parser.add_argument("--ocr-pdfs",   nargs="+", default=[], metavar="FILE")
parser.add_argument("--skip-ocr",   action="store_true")
parser.add_argument("--fail-fast",  action="store_true")
ARGS = parser.parse_args()

BASE = ARGS.url.rstrip("/")

STATE: dict[str, Any] = {
    "token":           None,
    "refresh_token":   None,
    "user_id":         None,
    "expense_id":      None,
    "income_id":       None,
    "recurring_id":    None,
    "netflix_id":      None,
    "group_id":        None,
    "member_id":       None,
    "shared_exp_id":   None,
    "ocr_created_ids": [],
}

RESULTS: list[dict] = []
CURRENT_SECTION: str = "SETUP"
_case_counter = [0]


def _next_case() -> str:
    _case_counter[0] += 1
    return f"case{_case_counter[0]}"


def headers(extra: dict = None) -> dict:
    h = {"Content-Type": "application/json"}
    if STATE["token"]:
        h["Authorization"] = f"Bearer {STATE['token']}"
    if extra:
        h.update(extra)
    return h


def _record(case_id: str, name: str, method: str, url: str,
            status: int, elapsed_ms: float, passed: bool,
            note: str = "", response_body: str = ""):

    RESULTS.append({
        "case_id":       case_id,
        "section":       CURRENT_SECTION,
        "name":          name,
        "method":        method,
        "url":           url,
        "status":        status,
        "elapsed_ms":    elapsed_ms,
        "passed":        passed,
        "note":          note,
        "response_body": response_body,
    })

    badge = "PASS" if passed else "FAIL"
    print(f"#{case_id}")
    print(f"  {badge}  [{status}]  {elapsed_ms:>7.1f}ms  {name}" +
          (f"  ({note})" if note else ""))

    if not passed:
        print(f"  FAILURE #{case_id}")
        print(f"    Section  : {CURRENT_SECTION}")
        print(f"    Request  : {method} {url}")
        print(f"    Status   : {status}")
        if note:
            print(f"    Note     : {note}")
        if response_body:
            lines = response_body.strip().splitlines()
            print(f"    Response :")
            for line in lines[:8]:
                print(f"      {line}")
            if len(lines) > 8:
                print(f"      ... ({len(lines) - 8} more lines)")

    if not passed and ARGS.fail_fast:
        print_summary()
        sys.exit(1)


def req(name: str, method: str, path: str, *,
        expected: int | list[int] = 200,
        json_body=None, params=None,
        extra_headers: dict = None,
        files=None,
        capture: dict = None,
        note: str = "") -> requests.Response | None:

    case_id = _next_case()
    url = f"{BASE}{path}"
    expected_codes = [expected] if isinstance(expected, int) else expected

    try:
        t0 = time.perf_counter()
        if files:
            resp = requests.request(
                method, url,
                headers={k: v for k, v in headers(extra_headers).items()
                         if k != "Content-Type"},
                files=files, params=params, timeout=30,
            )
        else:
            resp = requests.request(
                method, url,
                headers=headers(extra_headers),
                json=json_body, params=params, timeout=30,
            )
        elapsed = (time.perf_counter() - t0) * 1000
        passed  = resp.status_code in expected_codes

        if capture and passed:
            try:
                body = resp.json()
                for state_key, json_path in capture.items():
                    val = body
                    for part in json_path.split("."):
                        val = val[part]
                    STATE[state_key] = val
            except Exception:
                pass

        resp_body = ""
        if not passed:
            ct = resp.headers.get("Content-Type", "")
            if "json" in ct or "text" in ct or "xml" in ct:
                try:
                    resp_body = resp.text
                except Exception:
                    pass

        _record(case_id, name, method, url, resp.status_code,
                elapsed, passed, note=note, response_body=resp_body)
        return resp

    except requests.exceptions.ConnectionError:
        _record(case_id, name, method, url, 0, 0, False,
                note="CONNECTION REFUSED — is the gateway running?")
        return None
    except Exception as e:
        _record(case_id, name, method, url, 0, 0, False, note=str(e))
        return None


def section(title: str):
    global CURRENT_SECTION
    CURRENT_SECTION = title
    print(f"\n{'─'*64}")
    print(f"  {title}")
    print(f"{'─'*64}")


# ─────────────────────────────────────────────────────────────────────────────
#  AUTH SERVICE
# ─────────────────────────────────────────────────────────────────────────────

def test_auth():
    section("AUTH SERVICE")

    # case: health check
    req("Health check", "GET", "/api/auth/health", expected=200)

    # case: register new user (409 if already exists is fine)
    req("Register new user", "POST", "/api/auth/register",
        json_body={"email": ARGS.new_email, "password": "NewPass999!", "role": "USER"},
        expected=[200, 201, 409],
        note="409 = already exists, acceptable")

    # case: duplicate register must 409
    req("Register duplicate -> 409", "POST", "/api/auth/register",
        json_body={"email": ARGS.new_email, "password": "NewPass999!", "role": "USER"},
        expected=409)

    # case: weak password must 400
    req("Register weak password -> 400", "POST", "/api/auth/register",
        json_body={"email": "weak@test.com", "password": "abc", "role": "USER"},
        expected=400)

    req("Register main user", "POST", "/api/auth/register",
        json_body={"email": ARGS.email, "password": ARGS.password, "role": "USER"},
        expected=[200, 201, 409])

    # case: login with valid credentials
    resp = req("Login valid credentials", "POST", "/api/auth/login",
               json_body={"email": ARGS.email, "password": ARGS.password},
               expected=200,
               capture={"token": "token", "refresh_token": "refreshToken", "user_id": "userId"})
    if resp and resp.status_code == 200:
        print(f"    userId = {STATE['user_id']}")
    else:
        print(f"\n  FATAL: Login failed — cannot continue without a valid token.")
        print(f"  Fix: register the user first:")
        print(f"    curl -s -X POST {BASE}/api/auth/register \\")
        print(f"      -H 'Content-Type: application/json' \\")
        print(f"      -d '{{\"email\":\"{ARGS.email}\",\"password\":\"{ARGS.password}\",\"role\":\"USER\"}}'")
        print_summary()
        sys.exit(1)

    # case: wrong password must 401
    req("Login wrong password -> 401", "POST", "/api/auth/login",
        json_body={"email": ARGS.email, "password": "wrongpassword"},
        expected=401)

    # case: non-existent user must 401
    req("Login non-existent user -> 401", "POST", "/api/auth/login",
        json_body={"email": "nobody@nowhere.com", "password": "x"},
        expected=401)

    # case: GET /me authenticated
    req("GET /me authenticated", "GET", "/api/auth/me", expected=200)

    # case: GET /me without token must 401
    saved = STATE["token"]
    STATE["token"] = None
    req("GET /me unauthenticated -> 401", "GET", "/api/auth/me", expected=401)
    STATE["token"] = saved

    # case: refresh token
    if STATE["refresh_token"]:
        req("Refresh token", "POST", "/api/auth/refresh",
            json_body={"refreshToken": STATE["refresh_token"]},
            expected=200,
            capture={"token": "token", "refresh_token": "refreshToken"})

    # case: change password
    req("Change password", "POST", "/api/auth/change-password",
        json_body={"currentPassword": ARGS.password, "newPassword": ARGS.password},
        expected=200)

    # case: logout
    if STATE["refresh_token"]:
        req("Logout", "POST", "/api/auth/logout",
            json_body={"refreshToken": STATE["refresh_token"]},
            expected=200)

        # case: re-login after logout to restore token
        req("Re-login after logout", "POST", "/api/auth/login",
            json_body={"email": ARGS.email, "password": ARGS.password},
            expected=200,
            capture={"token": "token", "refresh_token": "refreshToken", "user_id": "userId"})


# ─────────────────────────────────────────────────────────────────────────────
#  UPSERT SERVICE
# ─────────────────────────────────────────────────────────────────────────────

def test_upsert():
    section("UPSERT SERVICE")

    uid = STATE["user_id"]

    # case: create expense
    resp = req("Create EXPENSE (Swiggy)", "POST", "/api/upsert/create",
               json_body={
                   "userId": uid, "name": "Swiggy Food Order",
                   "amount": 450.00, "type": "EXPENSE", "currency": "INR",
                   "expenseCategory": "FOOD_AND_DINING",
                   "description": "Dinner order from Swiggy",
               },
               expected=201,
               capture={"expense_id": "id"})
    if resp:
        print(f"    expense_id = {STATE['expense_id']}")

    # case: create income
    resp = req("Create INCOME (Salary)", "POST", "/api/upsert/create",
               json_body={
                   "userId": uid, "name": "Monthly Salary",
                   "amount": 75000.00, "type": "INCOME", "currency": "INR",
                   "incomeCategory": "SALARY",
                   "description": "June 2026 salary credit",
               },
               expected=201,
               capture={"income_id": "id"})
    if resp:
        print(f"    income_id = {STATE['income_id']}")

    # case: idempotency key first call
    import uuid
    idem_key = f"netflix-idem-{uuid.uuid4().hex[:8]}"
    resp1 = req("Create with idempotency key (1st call)", "POST", "/api/upsert/create",
                json_body={
                    "userId": uid, "name": "Netflix Subscription",
                    "amount": 649.00, "type": "EXPENSE", "currency": "INR",
                    "expenseCategory": "ENTERTAINMENT",
                    "description": "Monthly Netflix plan",
                },
                extra_headers={"X-Idempotency-Key": idem_key},
                expected=201,
                capture={"netflix_id": "id"})

    # case: idempotency key second call — same id expected
    resp2 = req("Create with idempotency key (2nd call, same key)", "POST", "/api/upsert/create",
                json_body={
                    "userId": uid, "name": "Netflix Subscription",
                    "amount": 649.00, "type": "EXPENSE", "currency": "INR",
                    "expenseCategory": "ENTERTAINMENT",
                    "description": "Monthly Netflix plan",
                },
                extra_headers={"X-Idempotency-Key": idem_key},
                expected=201)
    if resp1 and resp2 and resp1.status_code == 201 and resp2.status_code == 201:  # noqa
        id1 = resp1.json().get("id")
        id2 = resp2.json().get("id")
        same = id1 == id2
        print(f"  {'PASS' if same else 'FAIL'}  Idempotency check: id1={id1} == id2={id2}")

    # case: create recurring transaction
    req("Create RECURRING (Swimming)", "POST", "/api/upsert/create",
        json_body={
            "userId": uid, "name": "Swimming Membership",
            "amount": 2000.00, "type": "EXPENSE", "currency": "INR",
            "expenseCategory": "HEALTHCARE",
            "description": "Monthly swimming membership",
            "recurring": True, "recurringPeriod": "MONTHLY",
        },
        expected=201,
        capture={"recurring_id": "id"})

    # case: missing required field must 400
    req("Create missing required field -> 400", "POST", "/api/upsert/create",
        json_body={"userId": uid, "type": "EXPENSE"},
        expected=400)

    # case: userId mismatch must 403
    req("Create userId mismatch -> 403", "POST", "/api/upsert/create",
        json_body={
            "userId": "00000000-0000-0000-0000-000000000000",
            "name": "Bad Request", "amount": 1.0, "type": "EXPENSE",
            "currency": "INR", "expenseCategory": "OTHERS",
        },
        expected=403)

    # case: unauthenticated create must 401
    saved = STATE["token"]
    STATE["token"] = None
    req("Create unauthenticated -> 401", "POST", "/api/upsert/create",
        json_body={"userId": uid, "name": "X", "amount": 1.0,
                   "type": "EXPENSE", "currency": "INR", "expenseCategory": "OTHERS"},
        expected=401)
    STATE["token"] = saved

    # case: full PUT update
    if STATE["expense_id"]:
        req("Update expense (PUT)", "PUT", "/api/upsert/update",
            json_body={
                "id": STATE["expense_id"], "userId": uid,
                "name": "Zomato Food Order", "amount": 520.00,
                "type": "EXPENSE", "currency": "INR",
                "expenseCategory": "FOOD_AND_DINING",
                "description": "Updated to Zomato",
            },
            expected=200)

        # case: update wrong owner must 403
        req("Update wrong owner -> 403", "PUT", "/api/upsert/update",
            json_body={
                "id": STATE["expense_id"],
                "userId": "00000000-0000-0000-0000-000000000000",
                "name": "Hack", "amount": 1.0, "type": "EXPENSE",
                "currency": "INR", "expenseCategory": "OTHERS",
            },
            expected=403)

    # case: patch amount
    if STATE["expense_id"]:
        req("Patch amount", "PATCH",
            f"/api/upsert/entries/{STATE['expense_id']}/amount",
            params={"userId": uid},
            json_body={"amount": 999.99},
            expected=200)

        # case: patch negative amount must 400
        req("Patch amount negative -> 400", "PATCH",
            f"/api/upsert/entries/{STATE['expense_id']}/amount",
            params={"userId": uid},
            json_body={"amount": -50.0},
            expected=400)

    # case: list all entries page 0
    req("List all entries (page 0)", "GET", "/api/upsert/entries",
        params={"userId": uid, "page": 0, "size": 10},
        expected=200)

    # case: list EXPENSE only
    req("List EXPENSE only", "GET", "/api/upsert/entries",
        params={"userId": uid, "type": "EXPENSE", "page": 0, "size": 10},
        expected=200)

    # case: list INCOME only
    req("List INCOME only", "GET", "/api/upsert/entries",
        params={"userId": uid, "type": "INCOME", "page": 0, "size": 10},
        expected=200)

    # case: list with date range
    req("List with date range", "GET", "/api/upsert/entries",
        params={"userId": uid, "startDate": "2026-01-01",
                "endDate": "2026-12-31", "page": 0, "size": 10},
        expected=200)

    # case: list page 2 (may be empty)
    req("List page 2 (may be empty)", "GET", "/api/upsert/entries",
        params={"userId": uid, "page": 1, "size": 10},
        expected=200)

    # case: invalid userId must 400 or 404
    req("List invalid userId -> 400/404", "GET", "/api/upsert/entries",
        params={"userId": "not-a-uuid", "page": 0, "size": 10},
        expected=[400, 404])

    # case: get single entry by id
    if STATE["income_id"]:
        req("Get single entry by id", "GET",
            f"/api/upsert/entries/{STATE['income_id']}",
            params={"userId": uid},
            expected=200)

    # case: get non-existent entry must 404
    req("Get non-existent entry -> 404", "GET",
        "/api/upsert/entries/9999999",
        params={"userId": uid},
        expected=404)

    # case: search for salary
    req("Search 'salary'", "GET", "/api/upsert/search",
        params={"userId": uid, "q": "salary", "page": 0, "size": 10},
        expected=200)

    # case: search for zomato
    req("Search 'zomato'", "GET", "/api/upsert/search",
        params={"userId": uid, "q": "zomato", "page": 0, "size": 10},
        expected=200)

    # case: search with no results
    req("Search no results", "GET", "/api/upsert/search",
        params={"userId": uid, "q": "xyznonexistentquery", "page": 0, "size": 10},
        expected=200,
        note="expect empty page")

    # case: summary endpoint
    req("Summary", "GET", "/api/upsert/summary",
        params={"userId": uid},
        expected=200)

    # case: list recurring entries
    req("List recurring entries", "GET", "/api/upsert/recurring",
        params={"userId": uid},
        expected=200)

    # case: export CSV
    resp = req("Export CSV", "GET", "/api/upsert/entries/export",
               params={"userId": uid},
               expected=200)
    if resp and resp.status_code == 200:
        ct = resp.headers.get("Content-Type", "")
        cd = resp.headers.get("Content-Disposition", "")
        csv_ok = "text/csv" in ct and "attachment" in cd
        print(f"  {'PASS' if csv_ok else 'FAIL'}  CSV headers: Content-Type={ct!r}  Content-Disposition={cd!r}")

    # fetch ids for bulk delete
    list_resp = requests.get(f"{BASE}/api/upsert/entries",
                             headers=headers(),
                             params={"userId": uid, "page": 0, "size": 50},
                             timeout=10)
    bulk_ids = []
    if list_resp.status_code == 200:
        try:
            content = list_resp.json().get("content", [])
            for e in content:
                if e.get("id") in [STATE["netflix_id"], STATE["recurring_id"]]:
                    bulk_ids.append(e["id"])
        except Exception:
            pass

    # case: bulk delete netflix + recurring
    if bulk_ids:
        req("Bulk delete (netflix + recurring)", "POST", "/api/upsert/delete/bulk",
            params={"userId": uid},
            json_body=bulk_ids,
            expected=[200, 204])

    # case: bulk delete empty list
    req("Bulk delete empty list -> 400/200", "POST", "/api/upsert/delete/bulk",
        params={"userId": uid},
        json_body=[],
        expected=[200, 400])

    # case: soft delete income entry
    if STATE["income_id"]:
        req("Soft delete income entry", "DELETE",
            f"/api/upsert/delete/{STATE['income_id']}",
            params={"userId": uid},
            expected=[200, 204])

        # case: verify deleted entry returns 404
        req("Verify deleted entry gone -> 404", "GET",
            f"/api/upsert/entries/{STATE['income_id']}",
            params={"userId": uid},
            expected=404,
            note="should be 404 after soft delete")

    # case: delete non-existent entry must 404
    req("Delete non-existent -> 404", "DELETE",
        "/api/upsert/delete/9999999",
        params={"userId": uid},
        expected=404)

    # case: upsert health check
    req("Upsert health check", "GET", "/api/upsert/health", expected=200)


# ─────────────────────────────────────────────────────────────────────────────
#  ANALYTICS SERVICE
# ─────────────────────────────────────────────────────────────────────────────

def test_analytics():
    section("ANALYTICS SERVICE")

    uid = STATE["user_id"]
    now = datetime.now()
    start = (now - timedelta(days=365)).strftime("%Y-%m-%dT00:00:00")
    end   = now.strftime("%Y-%m-%dT23:59:59")

    # case: analytics health check
    req("Analytics health check", "GET", "/api/analytics/health", expected=200)

    # case: pie chart all transactions
    req("Pie chart - all", "GET", "/api/analytics/category-pie-chart",
        params={"userId": uid}, expected=200)

    # case: pie chart expense only
    req("Pie chart - EXPENSE only", "GET", "/api/analytics/category-pie-chart",
        params={"userId": uid, "transactionFilter": "EXPENSE"}, expected=200)

    # case: pie chart income only
    req("Pie chart - INCOME only", "GET", "/api/analytics/category-pie-chart",
        params={"userId": uid, "transactionFilter": "INCOME"}, expected=200)

    # case: pie chart with date range
    req("Pie chart - date range", "GET", "/api/analytics/category-pie-chart",
        params={"userId": uid, "startDate": start, "endDate": end}, expected=200)

    # case: pie chart invalid filter must 400
    req("Pie chart - invalid filter -> 400", "GET", "/api/analytics/category-pie-chart",
        params={"userId": uid, "transactionFilter": "INVALID"},
        expected=400)

    # case: timeline monthly
    req("Timeline - MONTHLY", "GET", "/api/analytics/timeline-chart",
        params={"userId": uid, "timelineType": "MONTHLY"}, expected=200)

    # case: timeline weekly
    req("Timeline - WEEKLY", "GET", "/api/analytics/timeline-chart",
        params={"userId": uid, "timelineType": "WEEKLY"}, expected=200)

    # case: timeline with date range
    req("Timeline - with date range", "GET", "/api/analytics/timeline-chart",
        params={"userId": uid, "timelineType": "MONTHLY",
                "startDate": start, "endDate": end},
        expected=200)

    # case: comprehensive monthly
    req("Comprehensive - MONTHLY", "GET", "/api/analytics/comprehensive",
        params={"userId": uid, "timelineType": "MONTHLY"}, expected=200)

    # case: comprehensive weekly
    req("Comprehensive - WEEKLY", "GET", "/api/analytics/comprehensive",
        params={"userId": uid, "timelineType": "WEEKLY"}, expected=200)

    # case: comprehensive with date range
    req("Comprehensive - with date range", "GET", "/api/analytics/comprehensive",
        params={"userId": uid, "timelineType": "MONTHLY",
                "startDate": start, "endDate": end},
        expected=200)

    # case: custom analytics POST
    req("Custom analytics POST", "POST", "/api/analytics/custom-analytics",
        json_body={
            "userId": uid, "timelineType": "MONTHLY",
            "startDate": start, "endDate": end,
        },
        expected=200)

    # case: custom analytics userId mismatch must 403
    req("Custom analytics userId mismatch -> 403", "POST", "/api/analytics/custom-analytics",
        json_body={
            "userId": "00000000-0000-0000-0000-000000000000",
            "timelineType": "MONTHLY",
        },
        expected=403)

    # case: transaction entries page 0
    req("Transaction entries page 0", "GET", "/api/analytics/transaction-entries",
        params={"userId": uid, "page": 0, "size": 10}, expected=200)

    # case: transaction entries page 1
    req("Transaction entries page 1", "GET", "/api/analytics/transaction-entries",
        params={"userId": uid, "page": 1, "size": 10}, expected=200)

    # case: income by category SALARY
    req("Income by category - SALARY", "GET",
        "/api/analytics/transactions/income-by-category",
        params={"userId": uid, "incomeCategory": "SALARY"}, expected=200)

    # case: income by category with date range
    req("Income by category - with date range", "GET",
        "/api/analytics/transactions/income-by-category",
        params={"userId": uid, "incomeCategory": "SALARY",
                "startDate": "2026-01-01", "endDate": "2026-12-31"},
        expected=200)

    # case: income by category invalid must 400
    req("Income by category - invalid -> 400", "GET",
        "/api/analytics/transactions/income-by-category",
        params={"userId": uid, "incomeCategory": "INVALID"},
        expected=400)

    # case: by type EXPENSE
    req("By type - EXPENSE", "GET", "/api/analytics/transactions/by-type",
        params={"userId": uid, "type": "EXPENSE"}, expected=200)

    # case: by type INCOME
    req("By type - INCOME", "GET", "/api/analytics/transactions/by-type",
        params={"userId": uid, "type": "INCOME"}, expected=200)

    # case: by type EXPENSE with date range
    req("By type - EXPENSE with date range", "GET", "/api/analytics/transactions/by-type",
        params={"userId": uid, "type": "EXPENSE",
                "startDate": "2026-01-01", "endDate": "2026-12-31"},
        expected=200)

    # case: unauthenticated must 401
    req("By type - unauthenticated -> 401", "GET", "/api/analytics/transactions/by-type",
        params={"userId": uid, "type": "EXPENSE"},
        extra_headers={"Authorization": "Bearer invalidtoken"},
        expected=401)


# ─────────────────────────────────────────────────────────────────────────────
#  SPLIT / GROUPS SERVICE
# ─────────────────────────────────────────────────────────────────────────────

def test_split():
    section("SPLIT / GROUPS SERVICE")

    uid = STATE["user_id"]

    # case: create group
    resp = req("Create group", "POST", "/api/upsert/groups",
               json_body={
                   "name": "Goa Trip 2026",
                   "description": "Group for Goa holiday expenses",
                   "createdBy": uid,
               },
               expected=201,
               capture={"group_id": "id"})
    if resp:
        print(f"    group_id = {STATE['group_id']}")

    # case: get user groups
    req("Get user groups", "GET", "/api/upsert/groups",
        params={"userId": uid}, expected=200)

    # case: get group by id
    if STATE["group_id"]:
        req("Get group by id", "GET",
            f"/api/upsert/groups/{STATE['group_id']}", expected=200)

    # case: get non-existent group must 404
    req("Get non-existent group -> 404", "GET",
        "/api/upsert/groups/9999999", expected=404)

    # case: create group missing name must 400
    req("Create group missing name -> 400", "POST", "/api/upsert/groups",
        json_body={"createdBy": uid},
        expected=400)

    if STATE["group_id"]:
        # case: add member to group (400 if already member from prior run)
        req("Add member to group", "POST",
            f"/api/upsert/groups/{STATE['group_id']}/members",
            json_body={"userId": uid, "name": "Jose", "email": ARGS.email},
            expected=[201, 400],
            note="400 = already a member from prior run, acceptable",
            capture={"member_id": "id"})

        # case: add member to non-existent group must 404
        req("Add member to non-existent group -> 404", "POST",
            "/api/upsert/groups/9999999/members",
            json_body={"userId": uid, "name": "Jose", "email": ARGS.email},
            expected=404)

        # case: get group members
        req("Get group members", "GET",
            f"/api/upsert/groups/{STATE['group_id']}/members",
            expected=200)

        # case: add shared expense
        req("Add shared expense", "POST",
            f"/api/upsert/groups/{STATE['group_id']}/expenses",
            json_body={
                "name": "Hotel booking",
                "amount": 12000.00,
                "currency": "INR",
                "paidBy": uid,
                "splitAmong": [uid],
                "description": "Hotel stay for Goa trip",
            },
            expected=201,
            capture={"shared_exp_id": "id"})

        # case: add expense to non-existent group must 404
        req("Add expense to non-existent group -> 404", "POST",
            "/api/upsert/groups/9999999/expenses",
            json_body={
                "name": "Dinner", "amount": 500.00,
                "currency": "INR", "paidBy": uid, "splitAmong": [uid],
                "description": "Dinner at the beach",
            },
            expected=404)

        # case: get group expenses
        req("Get group expenses", "GET",
            f"/api/upsert/groups/{STATE['group_id']}/expenses",
            expected=200)

        # case: get group balances
        req("Get group balances", "GET",
            f"/api/upsert/groups/{STATE['group_id']}/balances",
            expected=200)

        # case: settle debt same user (edge case)
        req("Settle debt (same user -> may 400)", "POST",
            f"/api/upsert/groups/{STATE['group_id']}/settle",
            params={"fromUserId": uid, "toUserId": uid},
            expected=[200, 400],
            note="same user settle is edge case")


# ─────────────────────────────────────────────────────────────────────────────
#  OCR / BILL PARSER SERVICE
# ─────────────────────────────────────────────────────────────────────────────

_IMAGE_MIME = {
    ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
    ".png": "image/png",  ".webp": "image/webp",
    ".gif": "image/gif",  ".bmp":  "image/bmp",
}

_DEFAULT_IMAGES = [
    "IdeaProjects/Personal-Finance-Assistant/requests/bill-parser/1.webp",
]
_DEFAULT_PDFS = [
    "IdeaProjects/Personal-Finance-Assistant/requests/bill-parser/Receipt.pdf",
]


def _resolve_ocr_files(arg_list: list[str], defaults: list[str]) -> list[Path]:
    candidates = arg_list if arg_list else [
        os.path.join(os.path.expanduser("~"), d) for d in defaults
    ]
    return [Path(p) for p in candidates if Path(p).exists()]


def _process_ocr_file(uid: str, path: Path, idx: int, total: int):
    suffix = path.suffix.lower()
    if suffix == ".pdf":
        mime     = "application/pdf"
        filename = "invoice.pdf"
        label    = "PDF"
    else:
        mime     = _IMAGE_MIME.get(suffix, "image/jpeg")
        filename = f"receipt{suffix}"
        label    = f"image ({suffix})"

    print(f"\n    [{idx}/{total}] {path.name}")

    with open(path, "rb") as f:
        # case: OCR upload
        resp = req(
            f"OCR {label} [{path.name}]", "POST",
            f"/api/bill/process/{uid}",
            files={"file": (filename, f, mime)},
            expected=200,
        )

    if not (resp and resp.status_code == 200):
        return

    try:
        ocr = resp.json()
        ocr_type = (ocr.get("type") or "EXPENSE").upper()
        entry_body = {
            "userId":          uid,
            "name":            ocr.get("name")        or f"OCR Import - {path.name}",
            "amount":          ocr.get("amount")      or 0.0,
            "type":            ocr_type,
            "currency":        ocr.get("currency")    or "INR",
            "description":     ocr.get("description") or f"Imported from {path.name}",
        }
        if ocr_type == "INCOME":
            entry_body["incomeCategory"] = ocr.get("incomeCategory") or "OTHERS"
        else:
            entry_body["expenseCategory"] = ocr.get("expenseCategory") or "OTHERS"
        # case: create entry from OCR result
        create_resp = req(
            f"Create entry from OCR [{path.name}]", "POST",
            "/api/upsert/create",
            json_body=entry_body,
            expected=201,
            note="chained from OCR",
        )
        if create_resp and create_resp.status_code == 201:
            created_id = create_resp.json().get("id")
            if created_id:
                STATE["ocr_created_ids"].append(created_id)
                print(f"    entry id={created_id} queued for cleanup")
    except Exception as e:
        print(f"  SKIP  Could not chain OCR->create: {e}")


def test_ocr():
    section("OCR / BILL PARSER SERVICE")

    uid = STATE["user_id"]

    if ARGS.skip_ocr:
        print("  SKIPPED  (--skip-ocr flag set)")
        return

    image_files = _resolve_ocr_files(ARGS.ocr_images, _DEFAULT_IMAGES)
    pdf_files   = _resolve_ocr_files(ARGS.ocr_pdfs,   _DEFAULT_PDFS)
    all_files   = image_files + pdf_files

    if not all_files:
        print("  SKIP  No OCR files found.")
        print("        Use --ocr-images file1.jpg  and/or  --ocr-pdfs file.pdf")
    else:
        print(f"    Found {len(image_files)} image(s), {len(pdf_files)} PDF(s)")
        for i, path in enumerate(all_files, 1):
            _process_ocr_file(uid, path, i, len(all_files))

    print()

    # use a real uid if available, else a dummy — just needs a valid path segment
    ocr_uid = uid or "00000000-0000-0000-0000-000000000000"

    # case: OCR missing file must 400
    req("OCR missing file -> 400", "POST",
        f"/api/bill/process/{ocr_uid}",
        expected=400)

    # case: OCR wrong file type must 400
    req("OCR wrong file type (JSON) -> 400", "POST",
        f"/api/bill/process/{ocr_uid}",
        files={"file": ("data.json", b'{"invalid":"file"}', "application/json")},
        expected=400)

    # case: OCR unauthenticated must 401
    req("OCR unauthenticated -> 401", "POST",
        "/api/bill/process/some-user-id",
        extra_headers={"Authorization": ""},
        files={"file": ("receipt.jpg", b"fakebytes", "image/jpeg")},
        expected=401)

    if STATE["ocr_created_ids"]:
        print(f"\n    {len(STATE['ocr_created_ids'])} OCR-created entries queued for cleanup: "
              f"{STATE['ocr_created_ids']}")


# ─────────────────────────────────────────────────────────────────────────────
#  CLEANUP
# ─────────────────────────────────────────────────────────────────────────────

def test_cleanup():
    section("CLEANUP - Delete all entries created this run")

    uid = STATE["user_id"]

    print(f"    Fetching all entries for userId={uid} ...")
    all_ids: list[int] = []
    page = 0
    while True:
        resp = requests.get(
            f"{BASE}/api/upsert/entries",
            headers=headers(),
            params={"userId": uid, "page": page, "size": 50},
            timeout=10,
        )
        if resp.status_code != 200:
            print(f"  WARN  Could not fetch page {page}: {resp.status_code}")
            break
        body    = resp.json()
        content = body.get("content", [])
        all_ids.extend(e["id"] for e in content)
        if body.get("last", True):
            break
        page += 1

    print(f"    Total entries found: {len(all_ids)}")

    if not all_ids:
        print("    Nothing to delete.")
        return

    batch_size = 50
    batches = [all_ids[i:i+batch_size] for i in range(0, len(all_ids), batch_size)]

    for i, batch in enumerate(batches, 1):
        # case: bulk delete batch
        req(
            f"Bulk delete batch {i}/{len(batches)} ({len(batch)} entries)",
            "POST", "/api/upsert/delete/bulk",
            params={"userId": uid},
            json_body=batch,
            expected=[200, 204],
        )

    # case: verify all entries deleted
    resp = req("Verify all entries deleted", "GET", "/api/upsert/entries",
               params={"userId": uid, "page": 0, "size": 10},
               expected=200)
    if resp and resp.status_code == 200:
        remaining = resp.json().get("totalElements", -1)
        print(f"  {'PASS' if remaining == 0 else 'FAIL'}  Remaining entries after cleanup: {remaining}")


# ─────────────────────────────────────────────────────────────────────────────
#  SUMMARY
# ─────────────────────────────────────────────────────────────────────────────

def print_summary():
    total  = len(RESULTS)
    passed = sum(1 for r in RESULTS if r["passed"])
    failed = total - passed
    avg_ms = sum(r["elapsed_ms"] for r in RESULTS) / total if total else 0
    slow   = [r for r in RESULTS if r["elapsed_ms"] > 1000]

    print(f"\n{'='*64}")
    print(f"  RESULTS")
    print(f"{'='*64}")
    print(f"  Total   : {total}")
    print(f"  Passed  : {passed}")
    if failed:
        print(f"  Failed  : {failed}")
    print(f"  Avg RT  : {avg_ms:.1f}ms")

    # ── Failure index ─────────────────────────────────────────────────────────
    if failed:
        failures = [r for r in RESULTS if not r["passed"]]

        print(f"\n  FAILURE INDEX  ({failed} failed)")
        print(f"  {'CASE':<10}  {'SECTION':<28}  TEST")
        print(f"  {'─'*10}  {'─'*28}  {'─'*30}")
        for r in failures:
            print(f"  #{r['case_id']:<9}  {r['section']:<28}  {r['name']}")

        print(f"\n  FAILURE DETAILS")
        for r in failures:
            print(f"\n  #{r['case_id']}  {r['section']} > {r['name']}")
            print(f"    {r['method']:<6}  {r['url']}")
            print(f"    Got status: {r['status']}")
            if r["note"]:
                print(f"    Note     : {r['note']}")
            if r["response_body"]:
                lines = r["response_body"].strip().splitlines()
                print(f"    Response :")
                for line in lines[:10]:
                    print(f"      {line}")
                if len(lines) > 10:
                    print(f"      ... ({len(lines) - 10} more lines)")

    # ── Slow requests ─────────────────────────────────────────────────────────
    if slow:
        print(f"\n  SLOW REQUESTS (>1000ms)")
        for r in sorted(slow, key=lambda x: -x["elapsed_ms"]):
            label = f"#{r['case_id']}" if not r["passed"] else ""
            print(f"  {r['elapsed_ms']:.0f}ms  {label}  {r['name']}")

    # ── Per-service breakdown ─────────────────────────────────────────────────
    print(f"\n  PER-SERVICE BREAKDOWN")
    services = {
        "Auth":      [r for r in RESULTS if "/auth"      in r["url"]],
        "Upsert":    [r for r in RESULTS if "/upsert"    in r["url"] and "/groups" not in r["url"]],
        "Analytics": [r for r in RESULTS if "/analytics" in r["url"]],
        "Split":     [r for r in RESULTS if "/groups"    in r["url"]],
        "OCR":       [r for r in RESULTS if "/bill"      in r["url"]],
        "Cleanup":   [r for r in RESULTS if r["section"].startswith("CLEANUP")],
    }
    print(f"  {'SERVICE':<12}  {'PASS/TOTAL':<12}  {'AVG RT':>8}  FAILED CASES")
    print(f"  {'─'*12}  {'─'*12}  {'─'*8}  {'─'*20}")
    for svc, runs in services.items():
        if not runs:
            continue
        ok        = sum(1 for r in runs if r["passed"])
        avg       = sum(r["elapsed_ms"] for r in runs) / len(runs)
        fail_tags = " ".join(f"#{r['case_id']}" for r in runs if not r["passed"])
        print(f"  {svc:<12}  {ok}/{len(runs):<11}  {avg:>7.1f}ms  {fail_tags or '—'}")

    print(f"\n{'='*64}")
    print(f"  {'ALL PASSED' if not failed else f'{failed} FAILED'}\n")


# ─────────────────────────────────────────────────────────────────────────────
#  ENTRY POINT
# ─────────────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    print(f"\n{'='*64}")
    print(f"  PERSONAL FINANCE ASSISTANT - API TEST SUITE")
    print(f"  {BASE}")
    print(f"  {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"{'='*64}")

    test_auth()
    test_upsert()
    test_analytics()
    test_split()
    test_ocr()
    test_cleanup()
    print_summary()